# Multi-Source Live Webcam Aggregator — configuration
# Copy this file to .env and fill in your settings.

# REQUIRED: YouTube Data API v3 key (https://console.cloud.google.com/)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Externally-reachable base URL. Used to build the /stream/<id> links in the
# playlist and the manifest-proxy URLs, so it must be the address clients
# actually reach (e.g. https://cams.example.com). Default suits LAN-only use.
PUBLIC_BASE_URL=http://localhost:8000

# Hours between catalogue refreshes (discovery + liveness). Minimum 1.
CATALOGUE_INTERVAL_HOURS=6

# YouTube search query for finding live webcams. `|`=OR, space=AND, `-`=exclude.
# Leave unset to use the built-in default.
# SEARCH_QUERY=cam|webcam|live|beach|wildlife|nature|traffic -gaming -asmr

# Categories to drop across ALL sources (comma-separated, case-insensitive). See the
# README "Filtering by category" section for the full list. Unset = keep everything.
# EXCLUDE_CATEGORIES=Religion,Sports

# Logging verbosity: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Concurrency for scraping + liveness during the catalogue build. Default is
# min(16, cpu*4). Lower it to reduce peak build-time memory (at the cost of a
# slower build). Leave unset to use the default.
# SCRAPE_WORKERS=8

# Proxy YouTube streams through the server (true/false). Default false: redirect
# players straight to YouTube — lower latency, but playback stops when YouTube's
# ~6h stream token expires (reselect to resume). Set true to keep it playing past
# that, at a small latency cost.
# PROXY_YOUTUBE=false

# How many sources discover + liveness-check at once (min 1). Total build concurrency is
# ~this × SCRAPE_WORKERS, so it bounds threads/sockets regardless of how many sources
# exist (extra sources queue). Leave unset to use the default.
# MAX_PARALLEL_SOURCES=4
