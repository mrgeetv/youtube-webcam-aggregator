{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-commit-to-main.sh",
            "if": "Bash(git commit*)"
          }
        ]
      }
    ]
  }
}
